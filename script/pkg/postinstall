#!/bin/sh
set -eu

SYSTEM_APP="/Library/Input Methods/Znak.app"
CONSOLE_USER=$(/usr/bin/stat -f %Su /dev/console 2>/dev/null || echo "")

if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ] && [ -d "$SYSTEM_APP" ]; then
    USER_HOME=$(/usr/bin/dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')
    if [ -n "$USER_HOME" ] && [ -d "$USER_HOME" ]; then
        USER_INPUT_METHODS="$USER_HOME/Library/Input Methods"
        USER_APP="$USER_INPUT_METHODS/Znak.app"
        /bin/mkdir -p "$USER_INPUT_METHODS"
        /bin/rm -rf "$USER_APP"
        /usr/bin/ditto "$SYSTEM_APP" "$USER_APP"
        /usr/sbin/chown -R "$CONSOLE_USER":staff "$USER_APP" >/dev/null 2>&1 || true
    fi
fi

/usr/bin/killall Znak >/dev/null 2>&1 || true

exit 0
