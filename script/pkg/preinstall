#!/bin/sh
set -eu

# Znak has historically been installed both per-user and system-wide during
# development. A system-wide pkg install does not replace a user-level input
# method with the same bundle id, and macOS may keep loading the stale user
# copy. Remove the old copies before installing the new bundle.
rm -rf "/Library/Input Methods/Znak.app"

for home in /Users/*; do
    [ -d "$home" ] || continue
    rm -rf "$home/Library/Input Methods/Znak.app"
done

exit 0
