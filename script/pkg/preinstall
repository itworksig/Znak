#!/bin/sh
set -eu

# Keep the system-wide target clean before pkgbuild installs the new payload.
# Do not remove user-level input methods here: macOS may have the input source
# registered against ~/Library/Input Methods/Znak.app, and deleting that path
# during install can make the input method disappear from Keyboard settings.
/usr/bin/killall Znak >/dev/null 2>&1 || true
rm -rf "/Library/Input Methods/Znak.app"

exit 0
